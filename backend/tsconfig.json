{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,

    "rootDir": "./src",
    "outDir": "./dist",

    //"types": ["node"],

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,

    "sourceMap": true
  },
  "include": ["src"]
}
